# Local Properties Example File
#
# This file must be renamed to `local.properties` in your local clone
# to successfully build the project.
#
# Replace the placeholder below with the actual Firebase Web API Key for the
# chatting-27210 project (found in Firebase Console -> Project Settings -> General)
# or your own Firebase project's Web API key if pointing to a different backend.

FIREBASE_WEB_API_KEY=YOUR_FIREBASE_API_KEY_HERE
